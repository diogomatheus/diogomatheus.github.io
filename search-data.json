---
layout: null
---
{
  {% for post in site.posts %}
  "{{ post.url | slugify: 'latin' }}": {
    "url": " {{ post.url | xml_escape }}",
    "title": "{{ post.title | xml_escape }}",
    "content": "{{ page.date | date: "%d/%m/%Y" }} - {{ page.content | markdownify | replace: '.', '. ' | replace: '</h2>', ': ' | replace: '</h3>', ': ' | replace: '</h4>', ': ' | replace: '</p>', ' ' | strip_html | strip_newlines | replace: '  ', ' ' | replace: '"', ' ' }}"
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
}